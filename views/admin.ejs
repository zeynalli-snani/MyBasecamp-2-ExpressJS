<%- include('partials/header') %>

<main class="admin-page">
  <div class="container">
    <h1>Admin Dashboard</h1>
    <p>Manage users and roles below.</p>

    <div class="card">
      <div class="table-container">
        <table class="user-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="user-list"></tbody>
        </table>
      </div>
    </div>
  </div>
</main>
<script>
  async function loadUsers() {
    const res = await fetch("/api/users");
    const users = await res.json();
    const list = document.getElementById("user-list");

    list.innerHTML = users
      .map(
        (u) => `
      <tr>
        <td>${u.id}</td>
        <td>${u.name}</td>
        <td>${u.email}</td>
        <td><span class="badge ${u.role}">${u.role}</span></td>
        <td>
          ${
            u.role !== "admin"
              ? `<button onclick="makeAdmin(${u.id})" class="btn-small">Make Admin</button>`
              : `<button onclick="removeAdmin(${u.id})" class="btn-small-outline">Remove Admin</button>`
          }
          <button onclick="deleteUser(${u.id})" class="btn-danger-small">Delete</button>
        </td>
      </tr>
    `,
      )
      .join("");
  }

  async function makeAdmin(id) {
    if (!confirm("Promote this user to admin?")) return;
    await fetch(`/api/users/${id}/admin`, { method: "PUT" });
    loadUsers();
  }

  async function removeAdmin(id) {
    if (!confirm("Remove admin privileges?")) return;
    await fetch(`/api/users/${id}/removeadmin`, { method: "PUT" });
    loadUsers();
  }

  async function deleteUser(id) {
    if (!confirm("Are you sure? This cannot be undone.")) return;
    await fetch(`/api/users/${id}`, { method: "DELETE" });
    loadUsers();
  }

  loadUsers();
</script>
